# Copy to .env and adjust as needed. Every value below is the default that
# applies when the variable is not set, so an empty .env changes nothing.
#
# docker-compose.yml sets MQTT_HOST/MQTT_PORT/DB_PATH for the containers
# itself; this file is mainly for running the services natively.

# --- Backend and simulator -------------------------------------------
# Broker location. Inside docker-compose this is the service name
# "mosquitto"; outside Docker it falls back to localhost.
MQTT_HOST=localhost
MQTT_PORT=1883

# --- Backend ----------------------------------------------------------
# SQLite file. Relative paths resolve against the backend working
# directory; the container uses /data/warehouse.db on a named volume.
DB_PATH=data/warehouse.db

# Readings and alerts older than this are deleted. Set to 0 to keep
# everything. /history never looks back further than 168 h.
RETENTION_DAYS=7

# How often the prune task runs. It also runs once at startup.
PRUNE_INTERVAL_SECONDS=3600

# --- Dashboard --------------------------------------------------------
# NOTE: these are read by Vite at BUILD time and inlined into the bundle -
# setting them on an already-built image has no effect. docker-compose
# passes VITE_API_BASE as a build arg. The value must be reachable from
# the browser, not from inside the container network.
VITE_API_BASE=http://localhost:8000

# Defaults to VITE_API_BASE with http swapped for ws; override only if the
# WebSocket is served from somewhere else.
# VITE_WS_BASE=ws://localhost:8000
